---
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  noindex?: boolean;
  socialImagePath?: string;
  socialImageAlt?: string;
  socialImageWidth?: number;
  socialImageHeight?: number;
};

const {
  title = "Lianghao Zhan | Data Science Portfolio",
  description = "Reproducible data science case studies in data engineering, geospatial analysis, operations research, NLP retrieval, forecasting and machine learning.",
  noindex = false,
  socialImagePath = "/assets/valencia-air-quality-observability-scorecard.png",
  socialImageAlt = "Valencia air-quality observability dashboard from Lianghao Zhan's data science portfolio.",
  socialImageWidth = 2682,
  socialImageHeight = 1129
} = Astro.props as Props;

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const homeUrl = new URL(basePath, Astro.site);
const socialLinks = ["https://github.com/0227lia", "https://www.linkedin.com/in/0227lia/"];
const socialImageUrl = new URL(`${basePath}${socialImagePath.replace(/^\//, "")}`, Astro.site);
const personId = `${homeUrl.href}#person`;
const websiteId = `${homeUrl.href}#website`;
const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": personId,
      name: "Lianghao Zhan",
      url: homeUrl.href,
      sameAs: socialLinks,
      affiliation: {
        "@type": "CollegeOrUniversity",
        name: "Universitat Politècnica de València"
      },
      knowsAbout: ["Data science", "Data engineering", "Machine learning", "SQL", "Data visualization"]
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: homeUrl.href,
      name: "Lianghao Zhan | Data Science Portfolio",
      author: { "@id": personId }
    },
    {
      "@type": "WebPage",
      "@id": `${canonicalUrl.href}#webpage`,
      url: canonicalUrl.href,
      name: title,
      description,
      isPartOf: { "@id": websiteId },
      author: { "@id": personId }
    }
  ]
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Lianghao Zhan" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#102f43" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="manifest" href={`${basePath}site.webmanifest`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Lianghao Zhan | Data Science Portfolio" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:image:width" content={String(socialImageWidth)} />
    <meta property="og:image:height" content={String(socialImageHeight)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <script type="application/ld+json" is:inline set:html={structuredData}></script>
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <div class="shell nav-shell">
        <a class="wordmark" href={basePath} aria-label="Data Science Portfolio home">
          <span class="wordmark-mark">LZ</span>
          <span>Lianghao Zhan</span>
        </a>
        <nav aria-label="Main navigation">
          <a href={`${basePath}#projects`}>Work</a>
          <a href={`${basePath}#evidence-index`}>Evidence</a>
          <a href={`${basePath}#contact`}>Contact</a>
        </nav>
      </div>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell footer-layout">
        <div>
          <p class="footer-title">Lianghao Zhan · Data Science Portfolio</p>
          <p>Student work built from public data, reproducible pipelines and explicit limitations.</p>
        </div>
        <div class="footer-links">
          <a href="https://github.com/0227lia" target="_blank" rel="noreferrer">GitHub profile</a>
          <a href="https://www.linkedin.com/in/0227lia/" target="_blank" rel="noreferrer">LinkedIn</a>
          <a href="https://github.com/0227lia/0227lia" target="_blank" rel="noreferrer">Profile README</a>
        </div>
      </div>
    </footer>
  </body>
</html>
