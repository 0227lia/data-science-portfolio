---
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Data Science Portfolio | 0227lia",
  description = "Reproducible data science case studies in data engineering, geospatial analysis, operations research, NLP retrieval, forecasting and machine learning."
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#16342b" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="manifest" href={`${basePath}site.webmanifest`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <div class="shell nav-shell">
        <a class="wordmark" href={basePath} aria-label="Data Science Portfolio home">
          <span class="wordmark-mark">DS</span>
          <span>Portfolio</span>
        </a>
        <nav aria-label="Main navigation">
          <a href={`${basePath}#projects`}>Projects</a>
          <a href={`${basePath}#practice`}>Practice</a>
          <a href="https://github.com/0227lia" target="_blank" rel="noreferrer">GitHub</a>
        </nav>
      </div>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell footer-layout">
        <div>
          <p class="footer-title">Data Science Portfolio</p>
          <p>Student work built from public data, reproducible pipelines and explicit limitations.</p>
        </div>
        <div class="footer-links">
          <a href="https://github.com/0227lia" target="_blank" rel="noreferrer">GitHub profile</a>
          <a href="https://github.com/0227lia/0227lia" target="_blank" rel="noreferrer">Profile README</a>
        </div>
      </div>
    </footer>
  </body>
</html>
