---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MetricStrip from "../../components/MetricStrip.astro";
import { projects, type Project } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props as { project: Project };
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title={`${project.title} | Data Science Portfolio`} description={project.description}>
  <section class="case-hero" aria-labelledby="case-title">
    <div class="shell case-hero-grid">
      <div class="case-hero-copy">
        <a class="back-link" href={`${basePath}#projects`}>Back to all projects</a>
        <p class="eyebrow">{project.eyebrow}</p>
        <h1 id="case-title">{project.title}</h1>
        <p>{project.summary}</p>
        <div class="case-hero-actions">
          <a class="primary-link primary-link-dark" href={project.githubUrl} target="_blank" rel="noreferrer">Open repository</a>
          <a class="secondary-link" href={project.sourceUrl} target="_blank" rel="noreferrer">Open data source</a>
        </div>
      </div>
      <img class="case-hero-image" src={`${basePath}${project.image.slice(1)}`} alt={project.imageAlt} width="1400" height="788" fetchpriority="high" />
    </div>
  </section>

  <section class="case-metrics-section">
    <div class="shell">
      <MetricStrip metrics={project.metrics} label={`${project.title} key metrics`} />
      <p class="metrics-note">Metrics come from the committed reproducible run in the linked repository. Their interpretation and limits are documented below.</p>
    </div>
  </section>

  <section class="case-content" aria-labelledby="case-question-title">
    <div class="shell case-grid">
      <aside class="case-sidebar" aria-label="Case study sections">
        <a href="#question">Question</a>
        <a href="#approach">Approach</a>
        <a href="#evidence">Evidence</a>
        <a href="#quality">Quality</a>
        <a href="#limits">Limits</a>
      </aside>
      <div class="case-sections">
        <section id="question">
          <p class="eyebrow">Question</p>
          <h2 id="case-question-title">What the project investigates.</h2>
          <p class="lead-copy">{project.challenge}</p>
        </section>
        <section id="approach">
          <p class="eyebrow">Approach</p>
          <h2>Method, in order.</h2>
          <ol class="method-list">
            {project.approach.map((step, index) => (
              <li>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <p>{step}</p>
              </li>
            ))}
          </ol>
        </section>
        <section id="evidence">
          <p class="eyebrow">Evidence</p>
          <h2>Results with context.</h2>
          <ul class="evidence-bullets">
            {project.evidence.map((item) => <li>{item}</li>)}
          </ul>
        </section>
        <section id="quality">
          <p class="eyebrow">Quality controls</p>
          <h2>How the work can be reviewed.</h2>
          <ul class="quality-list">
            {project.quality.map((item) => <li>{item}</li>)}
          </ul>
        </section>
        <section id="limits" class="limits-panel">
          <p class="eyebrow">Limits</p>
          <h2>What the output is not.</h2>
          <ul>
            {project.limitations.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      </div>
    </div>
  </section>

  <section class="project-footer-cta">
    <div class="shell project-footer-cta-layout">
      <div>
        <p class="eyebrow eyebrow-light">Repository</p>
        <h2>Inspect the code, data card and generated artifacts.</h2>
      </div>
      <a class="primary-link" href={project.githubUrl} target="_blank" rel="noreferrer">Open {project.title}</a>
    </div>
  </section>
</BaseLayout>
